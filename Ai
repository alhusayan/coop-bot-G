    payload = {
        "model": SEARCH_MODEL,
        "max_tokens": 1200,
        "temperature": 0,
        "tools": [{"type": "web_search_20250305", "name": "web_search",
                   "max_uses": max_searches}],
        "messages": [{"role": "user",
                      "content": EVALUATION_PROMPT.format(query=product_query,
                                                          price_line=price_line)}],
    }
    try:
        async with httpx.AsyncClient(timeout=120) as client:
            resp = await client.post(
                "https://api.anthropic.com/v1/messages",
                headers={
                    "x-api-key": ANTHROPIC_API_KEY,
                    "anthropic-version": "2023-06-01",
                    "content-type": "application/json",
                },
                json=payload,
            )
            resp.raise_for_status()
            data = resp.json()
    except httpx.HTTPError as e:
        print("EVAL ERROR:", repr(e))
        return {}
    text = "".join(
        block.get("text", "")
        for block in data.get("content", [])
        if block.get("type") == "text"
    )
    result = _parse_evaluation(text)
    print("EVAL:", json.dumps(result, ensure_ascii=False))
    return result


SMART_CARD_PROMPT = """أنت مستشار شراء كويتي محترف. المطلوب تقرير شراء كامل عن هذا المنتج بضربة وحدة:

المنتج: {query}
{price_line}

ابحث عن:
1. أسعاره الحالية في الكويت (إكسايت، بست اليوسفي، أوان، ديجومارت، المتاجر المتخصصة، الوكيل الرسمي — حسب نوع المنتج). للسيارات: سعر الوكالة وسعر المستعمل التقريبي.
2. تقييمات المستخدمين والمشاكل الشائعة المعروفة.
3. أفضل بديل أو اثنين بنفس الفئة السعرية.

أرجع JSON فقط — بدون أي نص قبله أو بعده:
{{
  "product_name": "اسم المنتج الكامل الواضح",
  "prices": [{{"store": "اسم المتجر بالعربي", "price": 0.000, "url": "الرابط"}}],
  "verdict": "جملة حكم وحدة صريحة بالكويتي",
  "score": 8,
  "pros": ["ميزة", "ميزة", "ميزة"],
  "cons": ["عيب", "عيب"],
  "price_opinion": "السعر العادل بالكويت بجملة وحدة",
  "alternatives": ["بديل بسعره التقريبي"]
}}

قواعد صارمة:
- الأسعار: فقط اللي شفتها فعلاً بنتيجة أو صفحة، بالدينار الكويتي، لنفس المنتج. لا تخمّن. إذا ما لقيت أسعار: []
- كن صريحاً بالعيوب — المشاكل المعروفة أهم معلومة بالتقرير.
- pros أقصاها 3 و cons أقصاها 2، كل نقطة أقل من 10 كلمات.
- score من 1 إلى 10 (قيمة مقابل سعر + جودة + موثوقية).
- أقصى 4 أسعار و 2 بدائل.
"""


def _parse_smart_card(text: str) -> dict:
    start, end = text.find("{"), text.rfind("}")
    if start == -1 or end == -1:
        return {}
    try:
        data = json.loads(text[start:end + 1])
    except json.JSONDecodeError:
        return {}
    if not isinstance(data, dict):
        return {}
    # الأسعار — نفس تحقق البحث القديم
    prices = []
    for item in data.get("prices") or []:
        if not isinstance(item, dict):
            continue
        store = str(item.get("store") or "").strip()
        try:
            price = float(item.get("price"))
        except (TypeError, ValueError):
            continue
        if store and 0.05 <= price <= 100000:   # سقف أعلى — فيه سيارات
            prices.append({"store": store, "price": price,
                           "url": str(item.get("url") or "").strip()})
    data["prices"] = prices[:4]
    # التقييم
    try:
        data["score"] = max(1, min(10, int(data.get("score", 0))))
    except (TypeError, ValueError):
        data["score"] = None
    for k in ("pros", "cons", "alternatives"):
        v = data.get(k)
        data[k] = [str(x).strip() for x in v][:3] if isinstance(v, list) else []
    data["product_name"] = str(data.get("product_name") or "").strip()
    data["verdict"] = str(data.get("verdict") or "").strip()
    # البطاقة مفيدة إذا فيها أسعار أو حكم
    if not data["prices"] and not data["verdict"]:
        return {}
    return data


