"""استخراج بيانات المنتج من الصورة عبر Claude Haiku
نقاط مهمة:
- temperature = 0 → نفس الصورة تعطي نفس النتيجة كل مرة (يحل مشكلة "مرة يلقاه ومرة لا")
- الاسم يُستخرج باللغتين للمطابقة عبر المصادر
- الرد JSON فقط، مع تنظيف أي Markdown fences قبل الـ parse
"""
import os
import json
import base64

import httpx

ANTHROPIC_API_KEY = os.environ.get("ANTHROPIC_API_KEY", "")
AI_MODEL = os.environ.get("AI_MODEL", "claude-haiku-4-5-20251001")
SEARCH_MODEL = os.environ.get("SEARCH_MODEL", AI_MODEL)

SEARCH_PRICES_PROMPT = """ابحث عن السعر الحالي لهذا المنتج في مواقع البقالة الكويتية:

المنتج: {query}

المصادر المعتمدة (ابحث فيها فقط):
- جمعية دوت كوم (jm3eia.com)
- طلبات مارت (talabat.com)
- كارفور الكويت
- نينجا الكويت
- أسواق التميمي أو اللولو إن وجدت

أرجع JSON فقط — مصفوفة بدون أي نص قبلها أو بعدها:
[{{"store": "اسم المتجر بالعربي", "price": 0.000, "product_name": "اسم المنتج كما وجدته", "url": "رابط الصفحة"}}]

قواعد صارمة:
- أدرج فقط أسعاراً شفتها فعلاً في نتيجة بحث أو صفحة، لنفس المنتج (نفس الماركة والحجم) أو الأقرب له جداً.
- السعر رقم عشري بالدينار الكويتي فقط، بين 0.05 و 500.
- لا تخمّن سعراً أبداً. إذا ما لقيت شي موثوق أرجع: []
- أقصى 4 نتائج.
"""


def _parse_price_results(text: str) -> list:
    """تحليل مصفوفة نتائج البحث مع تحقق صارم من كل عنصر"""
    start, end = text.find("["), text.rfind("]")
    if start == -1 or end == -1:
        return []
    try:
        data = json.loads(text[start:end + 1])
    except json.JSONDecodeError:
        return []
    out = []
    for item in data if isinstance(data, list) else []:
        if not isinstance(item, dict):
            continue
        store = str(item.get("store") or "").strip()
        try:
            price = float(item.get("price"))
        except (TypeError, ValueError):
            continue
        if not store or not (0.05 <= price <= 500):
            continue
        out.append({
            "store": store,
            "price": price,
            "product_name": str(item.get("product_name") or "").strip(),
            "url": str(item.get("url") or "").strip(),
        })
    return out[:4]


async def search_prices_online(product_query: str, max_searches: int = 5) -> list:
    """بحث حي عن أسعار المنتج بمواقع البقالة الكويتية — يُستخدم فقط
    لما القاعدة المحلية ما تلقى المنتج (fallback)"""
    if not ANTHROPIC_API_KEY or not product_query.strip():
        return []
    payload = {
        "model": SEARCH_MODEL,
        "max_tokens": 1200,
        "temperature": 0,
        "tools": [{"type": "web_search_20250305", "name": "web_search",
                   "max_uses": max_searches}],
        "messages": [{"role": "user",
                      "content": SEARCH_PRICES_PROMPT.format(query=product_query)}],
    }
    try:
        async with httpx.AsyncClient(timeout=120) as client:
            resp = await client.post(
                "https://api.anthropic.com/v1/messages",
                headers={
                    "x-api-key": ANTHROPIC_API_KEY,
                    "anthropic-version": "2023-06-01",
                    "content-type": "application/json",
                },
                json=payload,
            )
            resp.raise_for_status()
            data = resp.json()
    except httpx.HTTPError as e:
        print("ONLINE SEARCH ERROR:", repr(e))
        return []
    text = "".join(
        block.get("text", "")
        for block in data.get("content", [])
        if block.get("type") == "text"
    )
    results = _parse_price_results(text)
    print("ONLINE SEARCH:", json.dumps(results, ensure_ascii=False))
    return results

EXTRACTION_PROMPT = """أنت نظام استخراج بيانات منتجات من صور. الصور نوعان:
1. لقطات شاشة من تطبيقات/مواقع تسوق كويتية (فيها اسم مكتوب وسعر ورمز منتج)
2. صور حقيقية لمنتجات على رفوف الجمعيات (اقرأ العبوة نفسها: الماركة، النوع، الحجم)

استخرج وأرجع JSON فقط — بدون أي نص قبله أو بعده، وبدون Markdown:

{
  "product_name_ar": "الماركة + نوع المنتج بالعربي + الحجم. أو null",
