  "error": null
}

قاعدة حاسمة للاسم العربي: **ترجم المعنى، لا تكتب الإنجليزي بأحرف عربية**.
- "Ariel Fast Dissolving 3Kg" → "أريال مسحوق غسيل سريع الذوبان 3 كجم" ✅
- "أريل فاست ديسولفينج 3 كجم" ❌ (تعريب صوتي — ممنوع)
- "Sadia Whole Chicken" → "ساديا دجاج كامل" ✅ وليس "هول تشيكن" ❌
الماركة نفسها فقط (Ariel، Sadia) تنكتب بتعريبها المعروف.

قواعد صارمة:
- أرجع الاسم باللغتين دائماً — هذا ضروري للمطابقة، ترجم الناقص منهما.
- حوّل أي أرقام عربية (١٢٣) إلى إنجليزية (123) في كل الحقول.
- اكتب الوحدة دائماً بصيغة موحدة: كجم، جم، لتر، مل، حبة.
- بالصور الحقيقية: ركّز على الماركة والنوع والوزن المكتوب على العبوة (Net Weight).
- لا تخمّن معلومات غير مقروءة — الحقل غير الواضح = null.
- إذا الصورة ما فيها أي منتج واضح، أرجع: {"error": "no_product"}
"""

# تحويل الأرقام العربية إلى إنجليزية (طبقة أمان إضافية بعد الموديل)
AR_DIGITS = str.maketrans("٠١٢٣٤٥٦٧٨٩", "0123456789")


def _clean_json(text: str) -> dict:
    """تنظيف رد الموديل من أي fences أو نص زائد ثم parse"""
    text = text.strip()
    if text.startswith("```"):
        # إزالة ```json ... ```
        text = text.split("```")[1]
        if text.startswith("json"):
            text = text[4:]
    # أحياناً يسبق الـ JSON جملة قصيرة — نقتطع من أول { إلى آخر }
    start, end = text.find("{"), text.rfind("}")
    if start == -1 or end == -1:
        return {"error": "bad_json"}
    try:
        return json.loads(text[start:end + 1])
    except json.JSONDecodeError:
        return {"error": "bad_json"}


def _normalize_extraction(data: dict) -> dict:
    """توحيد المخرجات: أرقام إنجليزية، تحويل السعر لرقم، تنظيف الرمز"""
    out = {}
    for k, v in data.items():
        if isinstance(v, str):
            v = v.translate(AR_DIGITS).strip()
            if v in ("", "null", "None"):
                v = None
        out[k] = v

    # السعر → float
    if out.get("price_seen") is not None:
        try:
            out["price_seen"] = float(str(out["price_seen"]).replace("د.ك", "").strip())
        except (ValueError, TypeError):
            out["price_seen"] = None

    return out


async def extract_product_from_image(image_bytes: bytes, mime_type: str = "image/jpeg") -> dict:
    """ترسل الصورة لـ Haiku وترجع dict موحّد بالحقول المستخرجة"""
    if not ANTHROPIC_API_KEY:
        return {"error": "no_api_key"}

    b64 = base64.standard_b64encode(image_bytes).decode()

    payload = {
        "model": AI_MODEL,
        "max_tokens": 500,
        "temperature": 0,  # ← الأهم: نتيجة ثابتة لنفس الصورة
        "messages": [{
            "role": "user",
            "content": [
                {"type": "image",
                 "source": {"type": "base64", "media_type": mime_type, "data": b64}},
                {"type": "text", "text": EXTRACTION_PROMPT},
            ],
        }],
    }

    try:
        async with httpx.AsyncClient(timeout=60) as client:
            resp = await client.post(
                "https://api.anthropic.com/v1/messages",
                headers={
                    "x-api-key": ANTHROPIC_API_KEY,
                    "anthropic-version": "2023-06-01",
                    "content-type": "application/json",
                },
                json=payload,
            )
            resp.raise_for_status()
            data = resp.json()
    except httpx.HTTPError as e:
        print("AI HTTP ERROR:", repr(e))
        return {"error": "api_error"}

    text = "".join(
        block.get("text", "")
        for block in data.get("content", [])
        if block.get("type") == "text"
    )
    parsed = _clean_json(text)
    if parsed.get("error"):
        return parsed
    return _normalize_extraction(parsed)


EVALUATION_PROMPT = """أنت مستشار شراء كويتي خبير وصريح. قيّم هذا المنتج للمشتري:

المنتج: {query}
{price_line}

ابحث عن: تقييمات المستخدمين، المشاكل الشائعة المعروفة، هل السعر عادل بسوق الكويت، وأفضل بديل أو اثنين بنفس الفئة السعرية.

أرجع JSON فقط — بدون أي نص قبله أو بعده:
{{
  "verdict": "جملة حكم وحدة صريحة بالكويتي: يستاهل / لا تشتريه / يستاهل بس بشرط...",
  "score": 8,
  "pros": ["ميزة 1", "ميزة 2", "ميزة 3"],
  "cons": ["عيب 1", "عيب 2"],
  "price_opinion": "رأي بجملة: السعر عادل/مبالغ فيه/فرصة — مقارنة بسوق الكويت",
  "alternatives": ["بديل 1 بسعره التقريبي", "بديل 2 بسعره التقريبي"]
}}

قواعد:
- score من 1 إلى 10 بناءً على القيمة مقابل السعر والجودة والموثوقية.
- كن صريحاً — إذا المنتج عليه مشاكل معروفة (موديل سيارة بمشكلة قير مثلاً) قلها بوضوح، هذا أهم شي بالتقييم.
- pros ثلاث نقاط قصيرة كحد أقصى، cons اثنتين كحد أقصى، كل نقطة أقل من 10 كلمات.
- alternatives فقط إذا فيه بدائل منطقية فعلاً، وإلا [].
- لا تخترع معلومات — اللي ما تلقاه لا تذكره.
"""


def _parse_evaluation(text: str) -> dict:
    start, end = text.find("{"), text.rfind("}")
    if start == -1 or end == -1:
        return {}
    try:
        data = json.loads(text[start:end + 1])
    except json.JSONDecodeError:
        return {}
    if not isinstance(data, dict) or not data.get("verdict"):
        return {}
    try:
        data["score"] = max(1, min(10, int(data.get("score", 0))))
    except (TypeError, ValueError):
        data["score"] = None
    for k in ("pros", "cons", "alternatives"):
        v = data.get(k)
        data[k] = [str(x).strip() for x in v][:3] if isinstance(v, list) else []
    return data


async def evaluate_product(product_query: str, price_seen=None, max_searches: int = 5) -> dict:
    """تقييم شرائي صريح للمنتج بالبحث الحي — يُستدعى بالطلب فقط (يكلّف بحث)"""
    if not ANTHROPIC_API_KEY or not product_query.strip():
